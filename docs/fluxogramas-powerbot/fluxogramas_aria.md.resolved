    HANDOVER --> N75

    N75(["👤 **Node 75** — TRANSFER\n─────────────────────\nTransferência para\natendente (user: 134031)"])

    N73{"🔀 **Node 73**\nintencao_detectada?"}
    N73 -->|"agendamento"| N39
    N73 -->|"cancelamento"| AGD_CANCEL["🟦 → Fluxo Cancelar"]
    N73 -->|"reagendamento"| AGD_REA["🟦 → Fluxo Reagendar"]
    N73 -->|"sair"| END87([🔴 Node 87 — END])
    N73 -->|"none"| N3["📋 → Menu Principal"]

    N21 -->|"21.2 — SAIR"| N38([🔴 Node 38 — END])
    N36 -->|"36.2 — fechar"| N88([🔴 Node 88 — END])

