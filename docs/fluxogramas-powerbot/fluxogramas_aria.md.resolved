    N21 --> N79{"🔀 **Node 79**\nidade < 17?"}
    N79 -->|"✅ menor de idade"| N80
    N79 -->|"❌ maior/igual"| N11

    N80([🔴 Node 80 — END\nMenor de idade])

    N11["🔵 **Node 11** — Mensagem\n─────────────────────\n_Um momento enquanto\nverifique os horários..._ ⏳"]
    N11 --> N9

    N9["🌐 **Node 9** — API N8N\n─────────────────────\nevento: verificacao\ndata_iso: {{ gpt:data_iso }}\nperiodo: {{ gpt:periodo }}\n─────────────────────\nResposta: success, horarios_disponiveis"]

    N9 -->|"✅ success = true"| N29
    N9 -->|"❌ success = false"| N24

    N29{"🔀 **Node 29**\nHorários disponíveis?"}
    N29 -->|"29.1 — true\nHá horários"| N26
    N29 -->|"29.2 — false\nSem horários"| N30
    N29 -->|"29.3 — erro\nnenhuma condição"| N24

