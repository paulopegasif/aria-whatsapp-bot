## 🟦 Fluxo 2 — Cancelar / Reagendar

```mermaid
flowchart TD
    START([🟢 3.2 Já tenho agendamento]) --> N84

    N84["📋 **Node 84** — Escolha\n─────────────────────\n_Deseja cancelar ou reagendar?_\nBotões: Cancelar | Reagendar"]

    N84 -->|"84.1 — Cancelar"| CANCEL
    N84 -->|"84.2 — Reagendar"| REAGEND

    %% ── CANCELAR ──
    subgraph CANCEL_FLOW ["❌ Cancelamento"]
        CANCEL["🔵 **Node 44** — Mensagem\n_Um momento enquanto\nverifique seu agendamento..._"]
        CANCEL --> N42

        N42["🌐 **Node 42** — API N8N\n─────────────────────\nevento: verificar_evento_id\ntelefone: {{ powerzap_phone }}\n─────────────────────\nResposta: existe_agendamento,\ncalendar_id, event_id,\ndata_hora, sumario_consulta"]

        N42 -->|"42.1 — existe = true"| N45
        N42 -->|"42.2 — none/erro"| N24C

        N45{"🔀 **Node 45**\nexiste agendamento?"}
        N45 -->|"45.1 — true"| N40
        N45 -->|"45.2 — false"| N46

        N46["🔵 **Node 46** — Mensagem\n_Não encontrei agendamento\ncom esse contato._\n→ Redireciona para triagem"]
        N46 --> TriagemC["🤖 Node 21\n(Triagem)"]

        N40["🤖 **Node 40** — IA Cancelamento\nasst_R106DbQu9AvR5Q90FeH2Urnc\n─────────────────────\nInforma consulta encontrada\nConfirma com paciente\nPergunta motivo\nAguarda confirmação\n─────────────────────\n📤 Vars: motivo_cancelamento\nSinal: CONFIRMAR_CANCELAMENTO"]

        N40 -->|"exit: CONFIRMAR_CANCELAMENTO"| N47
        N40 -->|"40.3 — erro/fail"| N24C

        N47["🌐 **Node 47** — API N8N\n─────────────────────\nevento: cancelamento\ntelefone: {{ powerzap_phone }}\ncalendar_id: {{ api:calendar_id }}\nevent_id: {{ api:event_id }}\n─────────────────────\n✅ Cria evento em 'Cancelamentos'\n🗑️ Deleta agendamento original"]

        N47 -->|"47.1 — success"| N48
        N47 -->|"47.2 — erro"| N24C

        N48["🔵 **Node 48** — Mensagem\n_Sua consulta foi cancelada.\nCaso queira remarcar,\nentre em contato novamente._"]
        N48 --> N49([🔴 Node 49 — END])

        N24C["🔵 **Node 24** — Fallback\n_Instabilidade pontual_"] --> HANDOVER_C["👤 Node 74/75\nTransfer para atendente"]
    end

    %% ── REAGENDAR ──
    subgraph REAGEND_FLOW ["🔄 Reagendamento"]
        REAGEND["🔵 **Node 50** — Mensagem\n_Um momento enquanto\nverififico seu agendamento atual..._"]
        REAGEND --> N61

        N61["🌐 **Node 61** — API N8N\n─────────────────────\nevento: get_data_base\n─────────────────────\nResposta: data_atual_timestamp_rea"]
        N61 --> N51

        N51["🌐 **Node 51** — API N8N\n─────────────────────\nevento: verificar_evento_id\ntelefone: {{ powerzap_phone }}\n─────────────────────\nResposta: existe_agendamento_reagendamento\ncalendar_id_reagendamento\nevent_id_reagendamento\nnome_completo_reagendamento"]

        N51 -->|"51.1 — existe"| N55
        N51 -->|"51.2 — none/erro"| N24R

        N55{"🔀 **Node 55**\n existe agendamento?"}
        N55 -->|"55.1 — true"| N54
        N55 -->|"55.2 — false"| N53

        N53["🔵 **Node 53** — Mensagem\n_Não encontrei agendamento.\nVou te redirecionar para\niniciar um agendamento._"]
        N53 --> TriagemR["🤖 Node 21\n(Triagem)"]

        N54["🤖 **Node 54** — IA Coleta Nova Data\nasst_HJH4P3fLV2w4rcYNMWASpHfX\n─────────────────────\nInforma consulta encontrada\nPergunta nova data\nPergunta novo período\n─────────────────────\n📤 Vars: nova_data, novo_periodo"]

        N54 -->|"exit: JSON com nova_data"| N62
